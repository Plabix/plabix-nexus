# ============================================================================
# Plabix Nexus — environment variables
# Copy this file to .env.local and fill in real values for local development.
# In production (Vercel), set the same variables under Project Settings ->
# Environment Variables instead of committing a .env file.
# ============================================================================

# --- Supabase -----------------------------------------------------------
# Found in your Supabase project: Settings -> API.
# The anon key is safe to expose to the browser (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# The service role key BYPASSES Row Level Security. Server-only — never
# prefix this with NEXT_PUBLIC_, never send it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenAI (or any OpenAI-compatible provider) --------------------------
# Used for both chat completions and embeddings via LangChain's OpenAI
# wrappers. To use a different provider, point OPENAI_BASE_URL at an
# OpenAI-compatible endpoint (e.g. Azure OpenAI, OpenRouter, a local
# vLLM/Ollama server) and adjust the model names below to match.
OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
